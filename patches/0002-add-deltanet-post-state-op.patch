+// ggml_deltanet_post_state — qinf downstream patch
+//
+// Fused post-state epoxy: gated = rms_norm(x, eps) * w_norm * silu(z).
+// Replaces a 4-op chain (rms_norm, mul, silu, mul) in the DeltaNet decode
+// path with a single dispatch. See qwen-inference/docs/plan-deltanet-fusion.md.
+
+struct ggml_tensor * ggml_deltanet_post_state(
+        struct ggml_context * ctx,
+        struct ggml_tensor  * x,
+        struct ggml_tensor  * z,
+        struct ggml_tensor  * w_norm,
+        float                 eps) {
+    GGML_ASSERT(ggml_is_contiguous(x));
+    GGML_ASSERT(ggml_is_contiguous(z));
+    GGML_ASSERT(ggml_is_contiguous(w_norm));
+
+    GGML_ASSERT(x->type      == GGML_TYPE_F32);
+    GGML_ASSERT(z->type      == GGML_TYPE_F32);
+    GGML_ASSERT(w_norm->type == GGML_TYPE_F32);
+
+    GGML_ASSERT(ggml_are_same_shape(x, z));
+    GGML_ASSERT(w_norm->ne[0] == x->ne[0]);
+    GGML_ASSERT(ggml_nelements(w_norm) == x->ne[0]);
+
+    struct ggml_tensor * result = ggml_dup_tensor(ctx, x);
+
+    ggml_set_op_params(result, &eps, sizeof(eps));
+
+    result->op     = GGML_OP_DELTANET_POST_STATE;
+    result->src[0] = x;
+    result->src[1] = z;
+    result->src[2] = w_norm;
+
+    return result;
+}
