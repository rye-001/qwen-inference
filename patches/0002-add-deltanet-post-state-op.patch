+// ggml_compute_forward_deltanet_post_state — qinf downstream patch
+//
+// Fused: gated[i] = (x[i] / rms(x_row) * w_norm[i]) * silu(z[i])
+// where rms(x_row) = sqrt(mean(x_row^2) + eps), per row of length ne00.
+// Equivalent to the chained 4-op graph: rms_norm(x, eps) * w_norm * silu(z),
+// fused into a single per-row pass to avoid 3 extra tensor-sized roundtrips
+// through scratch memory.
+//
+// Threading: outer rows split across threads via ith / nth, identical to
+// ggml_compute_forward_rms_norm_f32 — see that function for the canonical
+// pattern.
+
+static void ggml_compute_forward_deltanet_post_state_f32(
+        const ggml_compute_params * params,
+        ggml_tensor * dst) {
+
+    const ggml_tensor * src0 = dst->src[0]; // x
+    const ggml_tensor * src1 = dst->src[1]; // z
+    const ggml_tensor * src2 = dst->src[2]; // w_norm  [ne00] broadcast
+
+    GGML_ASSERT(ggml_are_same_shape(src0, dst));
+    GGML_ASSERT(ggml_are_same_shape(src0, src1));
+    GGML_ASSERT(src2->ne[0] == src0->ne[0]);
+    GGML_ASSERT(ggml_nelements(src2) == src0->ne[0]);
+
+    GGML_ASSERT(src0->nb[0] == sizeof(float));
+    GGML_ASSERT(src1->nb[0] == sizeof(float));
+    GGML_ASSERT(src2->nb[0] == sizeof(float));
+
+    const int ith = params->ith;
+    const int nth = params->nth;
+
+    GGML_TENSOR_TERNARY_OP_LOCALS
+
+    float eps;
+    memcpy(&eps, dst->op_params, sizeof(float));
+    GGML_ASSERT(eps >= 0.0f);
+
+    const float * w_norm = (const float *) src2->data;
+
+    for (int64_t i03 = 0; i03 < ne03; i03++) {
+        for (int64_t i02 = 0; i02 < ne02; i02++) {
+            for (int64_t i01 = ith; i01 < ne01; i01 += nth) {
+                const float * x_row = (const float *) ((const char *) src0->data + i01*nb01 + i02*nb02 + i03*nb03);
+                const float * z_row = (const float *) ((const char *) src1->data + i01*nb11 + i02*nb12 + i03*nb13);
+                float       * y_row =       (float *) (      (char *) dst->data  + i01*nb1  + i02*nb2  + i03*nb3);
+
+                ggml_float sum = 0.0;
+                for (int64_t i00 = 0; i00 < ne00; i00++) {
+                    sum += (ggml_float)(x_row[i00] * x_row[i00]);
+                }
+
+                const float scale = 1.0f / sqrtf((float)(sum / (ggml_float)ne00) + eps);
+                assert(scale > 0.0f);
+
+                for (int64_t i00 = 0; i00 < ne00; i00++) {
+                    const float zi      = z_row[i00];
+                    const float silu_zi = zi / (1.0f + expf(-zi));   // silu(z) = z * sigmoid(z)
+                    const float normed  = x_row[i00] * scale * w_norm[i00];
+                    y_row[i00]          = normed * silu_zi;
+                }
+            }
+        }
+    }
+}
+
+void ggml_compute_forward_deltanet_post_state(
+        const ggml_compute_params * params,
+        ggml_tensor * dst) {
+    const ggml_tensor * src0 = dst->src[0];
+
+    switch (src0->type) {
+        case GGML_TYPE_F32:
+            {
+                ggml_compute_forward_deltanet_post_state_f32(params, dst);
+            } break;
+        default:
+            {
+                GGML_ABORT("fatal error");
+            }
+    }
+}
+
