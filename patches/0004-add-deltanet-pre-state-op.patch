+// ggml_deltanet_pre_state — qinf downstream patch
+//
+// Fused pre-state epoxy: l2_norm(q, eps) + l2_norm(k, eps), each tile-repeated
+// from num_k_heads to num_v_heads (GQA broadcast). Output packs Q and K into
+// one tensor of shape [head_k_dim, 2 * num_v_heads, n_seq_tokens, n_seqs].
+// Replaces a 4-op chain (l2_norm × 2 + repeat_4d × 2) in the DeltaNet decode
+// path with a single dispatch. See qwen-inference/docs/plan-deltanet-fusion.md.
+//
+// We do NOT require q/k to be contiguous — the call site builds them as views
+// into the conv output and the kernel reads via per-axis strides. We DO require
+// their dim-0 stride to equal sizeof(float) (rows-contiguous), which the row
+// reduction relies on.
+
+struct ggml_tensor * ggml_deltanet_pre_state(
+        struct ggml_context * ctx,
+        struct ggml_tensor  * q,
+        struct ggml_tensor  * k,
+        int32_t               num_v_heads,
+        float                 eps) {
+    GGML_ASSERT(q->type == GGML_TYPE_F32);
+    GGML_ASSERT(k->type == GGML_TYPE_F32);
+
+    GGML_ASSERT(ggml_are_same_shape(q, k));
+    GGML_ASSERT(q->nb[0] == sizeof(float));
+    GGML_ASSERT(k->nb[0] == sizeof(float));
+
+    const int64_t num_k_heads = q->ne[1];
+    GGML_ASSERT(num_v_heads >  0);
+    GGML_ASSERT(num_k_heads >  0);
+    GGML_ASSERT(num_v_heads % num_k_heads == 0);
+
+    const int64_t head_k_dim   = q->ne[0];
+    const int64_t n_seq_tokens = q->ne[2];
+    const int64_t n_seqs       = q->ne[3];
+
+    struct ggml_tensor * result = ggml_new_tensor_4d(ctx, GGML_TYPE_F32,
+        head_k_dim, 2 * (int64_t) num_v_heads, n_seq_tokens, n_seqs);
+
+    int32_t params[2];
+    memcpy(&params[0], &eps,         sizeof(float));
+    memcpy(&params[1], &num_v_heads, sizeof(int32_t));
+    ggml_set_op_params(result, params, sizeof(params));
+
+    result->op     = GGML_OP_DELTANET_PRE_STATE;
+    result->src[0] = q;
+    result->src[1] = k;
+
+    return result;
+}
