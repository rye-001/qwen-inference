+// ggml_compute_forward_deltanet_pre_state — qinf downstream patch
+//
+// Fused: out[head, h, t, s] = (q_or_k[head, h % num_k_heads, t, s])
+//                              / max(sqrt(sum(row^2)), eps)
+//   where row = full head_k_dim row at (h % num_k_heads, t, s) of Q (when h < num_v_heads)
+//                                                                or K (when h >= num_v_heads).
+// Output shape: [head_k_dim, 2 * num_v_heads, n_seq_tokens, n_seqs]; rows are
+// packed: first num_v_heads are tile-repeated l2(Q), next num_v_heads are tile-repeated
+// l2(K). Tile-repeat semantics match ggml_repeat_4d (output[i1] = input[i1 % ne01]).
+//
+// Threading: rows split across threads (ith / nth). Each row is one (h, t, s)
+// triple where h ∈ [0, 2 * num_v_heads). Recompute the source row's l2 scale
+// per output row — heads in the same tile group share src rows but recomputing
+// is dispatch-cheap and trivially thread-safe.
+
+static void ggml_compute_forward_deltanet_pre_state_f32(
+        const ggml_compute_params * params,
+        ggml_tensor * dst) {
+
+    const ggml_tensor * src0 = dst->src[0]; // q
+    const ggml_tensor * src1 = dst->src[1]; // k
+
+    GGML_ASSERT(src0->type == GGML_TYPE_F32);
+    GGML_ASSERT(src1->type == GGML_TYPE_F32);
+    GGML_ASSERT(ggml_are_same_shape(src0, src1));
+    GGML_ASSERT(src0->nb[0] == sizeof(float));
+    GGML_ASSERT(src1->nb[0] == sizeof(float));
+    GGML_ASSERT(dst->nb[0]  == sizeof(float));
+
+    GGML_TENSOR_BINARY_OP_LOCALS
+
+    float   eps;
+    int32_t num_v_heads;
+    memcpy(&eps,         (const char *) dst->op_params + 0,             sizeof(float));
+    memcpy(&num_v_heads, (const char *) dst->op_params + sizeof(float), sizeof(int32_t));
+    GGML_ASSERT(eps >= 0.0f);
+    GGML_ASSERT(num_v_heads > 0);
+
+    const int64_t num_k_heads = ne01;        // src0/src1 dim 1
+    GGML_ASSERT(num_k_heads > 0);
+    GGML_ASSERT(num_v_heads % num_k_heads == 0);
+    GGML_ASSERT(ne0 == ne00);                // head_k_dim preserved
+    GGML_ASSERT(ne1 == 2 * (int64_t) num_v_heads);
+    GGML_ASSERT(ne2 == ne02);
+    GGML_ASSERT(ne3 == ne03);
+
+    const int ith = params->ith;
+    const int nth = params->nth;
+
+    const int64_t n_rows = (int64_t) ne1 * ne2 * ne3;
+
+    for (int64_t ir = ith; ir < n_rows; ir += nth) {
+        const int64_t i03 = ir / ((int64_t) ne1 * ne2);
+        const int64_t i02 = (ir / ne1) % ne2;
+        const int64_t i01 = ir % ne1;
+
+        const bool    is_k          = i01 >= num_v_heads;
+        const int64_t v_head_idx    = is_k ? (i01 - num_v_heads) : i01;
+        const int64_t src_head_idx  = v_head_idx % num_k_heads;
+        const ggml_tensor * src     = is_k ? src1 : src0;
+
+        const float * x = (const float *) ((const char *) src->data
+            + i03 * (is_k ? nb13 : nb03)
+            + i02 * (is_k ? nb12 : nb02)
+            + src_head_idx * (is_k ? nb11 : nb01));
+
+        float * y = (float *) ((char *) dst->data + i03*nb3 + i02*nb2 + i01*nb1);
+
+        ggml_float sum = 0.0;
+        for (int64_t i00 = 0; i00 < ne00; i00++) {
+            sum += (ggml_float) (x[i00] * x[i00]);
+        }
+
+        const float scale = 1.0f / fmaxf(sqrtf((float) sum), eps);
+
+        for (int64_t i00 = 0; i00 < ne00; i00++) {
+            y[i00] = x[i00] * scale;
+        }
+    }
+}
+
+void ggml_compute_forward_deltanet_pre_state(
+        const ggml_compute_params * params,
+        ggml_tensor * dst) {
+    const ggml_tensor * src0 = dst->src[0];
+
+    switch (src0->type) {
+        case GGML_TYPE_F32:
+            {
+                ggml_compute_forward_deltanet_pre_state_f32(params, dst);
+            } break;
+        default:
+            {
+                GGML_ABORT("fatal error");
+            }
+    }
+}
