+    uint64_t nb02;        // src0 stride (dim 2)
+    uint64_t nb03;        // src0 stride (dim 3)
+    uint64_t nb11;        // src1 stride (dim 1)
+    uint64_t nb12;        // src1 stride (dim 2)
+    uint64_t nb13;        // src1 stride (dim 3)
+    uint64_t nb1;         // dst stride (dim 1)
+    uint64_t nb2;         // dst stride (dim 2)
+    uint64_t nb3;         // dst stride (dim 3)
