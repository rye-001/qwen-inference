+// qinf downstream patch — Metal dispatch for fused DeltaNet pre-state op.
+// Mirrors the CPU forward in ggml/src/ggml-cpu/ops.cpp:
+//   for each output row (h, t, s):
+//     v_head = h < num_v_heads ? h : (h - num_v_heads);
+//     src    = h < num_v_heads ? Q : K;
+//     row    = src at (v_head % num_k_heads, t, s);
+//     scale  = 1 / max(sqrt(sum(row^2)), eps);
+//     dst[h, t, s][i00] = row[i00] * scale;
+// One threadgroup per output row (i01, i02, i03); 32 threads per group; each
+// thread strides across ne00 (head_k_dim, multiple of 32 — gated by supports_op).
+int ggml_metal_op_deltanet_pre_state(ggml_metal_op_t ctx, int idx) {
+    ggml_tensor * op = ctx->node(idx);
+
+    ggml_metal_library_t lib = ctx->lib;
+    ggml_metal_encoder_t enc = ctx->enc;
+
+    GGML_TENSOR_LOCALS( int32_t, ne0, op->src[0], ne);
+    GGML_TENSOR_LOCALS(uint64_t, nb0, op->src[0], nb);
+    GGML_TENSOR_LOCALS(uint64_t, nb1, op->src[1], nb);
+    GGML_TENSOR_LOCALS( int32_t, ne,  op,         ne);
+    GGML_TENSOR_LOCALS(uint64_t, nb,  op,         nb);
+
+    float   eps;
+    int32_t num_v_heads;
+    memcpy(&eps,         (const char *) op->op_params + 0,             sizeof(float));
+    memcpy(&num_v_heads, (const char *) op->op_params + sizeof(float), sizeof(int32_t));
+
+    auto pipeline = ggml_metal_library_get_pipeline_deltanet_pre_state(lib, op);
+
+    ggml_metal_kargs_deltanet_pre_state args = {
+        /*.ne00        =*/ ne00,
+        /*.num_k_heads =*/ ne01,
+        /*.num_v_heads =*/ num_v_heads,
+        /*.nb01        =*/ nb01,
+        /*.nb02        =*/ nb02,
+        /*.nb03        =*/ nb03,
+        /*.nb11        =*/ nb11,
+        /*.nb12        =*/ nb12,
+        /*.nb13        =*/ nb13,
+        /*.nb1         =*/ nb1,
+        /*.nb2         =*/ nb2,
+        /*.nb3         =*/ nb3,
+        /*.eps         =*/ eps,
+    };
+
+    int nth = 32;
+    while (nth < ne00 && nth < (int) ggml_metal_pipeline_max_theads_per_threadgroup(pipeline)) {
+        nth *= 2;
+    }
+    nth = std::min(nth, (int) ggml_metal_pipeline_max_theads_per_threadgroup(pipeline));
+    nth = std::min(nth, ne00);
+
+    const size_t smem = pipeline.smem;
+
+    ggml_metal_encoder_set_pipeline(enc, pipeline);
+    ggml_metal_encoder_set_bytes   (enc, &args, sizeof(args),                  0);
+    ggml_metal_encoder_set_buffer  (enc, ggml_metal_get_buffer_id(op->src[0]), 1); // q
+    ggml_metal_encoder_set_buffer  (enc, ggml_metal_get_buffer_id(op->src[1]), 2); // k
+    ggml_metal_encoder_set_buffer  (enc, ggml_metal_get_buffer_id(op),         3); // dst
+
+    ggml_metal_encoder_set_threadgroup_memory_size(enc, smem, 0);
+
+    // ne1 = 2 * num_v_heads (Q and K packed).
+    ggml_metal_encoder_dispatch_threadgroups(enc, ne1, ne2, ne3, nth, 1, 1);
+
+    return 1;
+}
