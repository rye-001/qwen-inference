+// qinf downstream patch — pipeline lookup for ggml_deltanet_post_state.
+// Single F32 variant; constraints enforced in supports_op (F32 + contiguous + ne00 % 32 == 0).
+ggml_metal_pipeline_with_params ggml_metal_library_get_pipeline_deltanet_post_state(ggml_metal_library_t lib, const ggml_tensor * op) {
+    assert(op->op == GGML_OP_DELTANET_POST_STATE);
+    GGML_ASSERT(op->src[0]->type == GGML_TYPE_F32);
+    GGML_ASSERT(op->src[1]->type == GGML_TYPE_F32);
+    GGML_ASSERT(op->src[2]->type == GGML_TYPE_F32);
+    GGML_ASSERT(op->src[0]->ne[0] % 32 == 0);
+
+    char base[256];
+    char name[256];
+
+    snprintf(base, 256, "kernel_deltanet_post_state_f32");
+    snprintf(name, 256, "%s", base);
+
+    ggml_metal_pipeline_with_params res = ggml_metal_library_get_pipeline(lib, name);
+    if (!res.pipeline) {
+        res = ggml_metal_library_compile_pipeline(lib, base, name, nullptr);
+    }
+
+    res.smem = 32*sizeof(float);
+
+    return res;
+}
